{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lz-bot.github.io/ecopath-pathway-explorer/schemas/ecopath-foreground.schema.json",
  "title": "ECO-PATH foreground inventory draft export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "export_type",
    "exported_at",
    "app",
    "language",
    "pathway",
    "functional_unit",
    "processes",
    "disclaimer"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "export_type": { "const": "ecopath_foreground_draft" },
    "exported_at": { "type": "string", "format": "date-time" },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "url"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "url": { "type": "string" }
      }
    },
    "language": { "type": "string", "minLength": 2 },
    "pathway": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "localized_label"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "localized_label": { "type": "string", "minLength": 1 }
      }
    },
    "functional_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clinicalFunction",
        "population",
        "startPoint",
        "endPoint",
        "timeHorizon",
        "geography",
        "referenceAmount",
        "referenceUnit",
        "comparability"
      ],
      "properties": {
        "clinicalFunction": { "type": "string" },
        "population": { "type": "string" },
        "startPoint": { "type": "string" },
        "endPoint": { "type": "string" },
        "timeHorizon": { "type": "string" },
        "geography": { "type": "string" },
        "referenceAmount": { "type": "number", "exclusiveMinimum": 0 },
        "referenceUnit": { "type": "string", "minLength": 1 },
        "comparability": { "type": "string" }
      }
    },
    "processes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/process" }
    },
    "disclaimer": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "process": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "process_id",
        "mapping_key",
        "module_id",
        "building_block",
        "draft_status",
        "reference_output",
        "metadata",
        "exchanges",
        "review"
      ],
      "properties": {
        "process_id": { "type": "string", "minLength": 1 },
        "mapping_key": { "type": "string", "minLength": 1 },
        "module_id": { "type": "string", "pattern": "^EM[0-9]{2}$" },
        "building_block": { "type": "string", "minLength": 1 },
        "draft_status": { "enum": ["draft", "review-ready"] },
        "reference_output": { "$ref": "#/$defs/reference_output" },
        "metadata": { "$ref": "#/$defs/metadata" },
        "exchanges": {
          "type": "array",
          "items": { "$ref": "#/$defs/exchange" }
        },
        "review": { "$ref": "#/$defs/review" }
      }
    },
    "reference_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "amount", "unit"],
      "properties": {
        "name": { "type": "string" },
        "amount": { "type": ["number", "null"], "exclusiveMinimum": 0 },
        "unit": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "location",
        "reference_year",
        "technology_description",
        "data_source",
        "allocation_method",
        "cut_off_note"
      ],
      "properties": {
        "location": { "type": "string" },
        "reference_year": { "type": ["integer", "null"], "minimum": 1900, "maximum": 2200 },
        "technology_description": { "type": "string" },
        "data_source": { "type": "string" },
        "allocation_method": { "type": "string" },
        "cut_off_note": { "type": "string" }
      }
    },
    "exchange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exchange_id",
        "name",
        "flow_type",
        "direction",
        "amount",
        "unit",
        "provider_database",
        "provider_code",
        "data_source",
        "uncertainty"
      ],
      "properties": {
        "exchange_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "flow_type": { "enum": ["technosphere", "biosphere", "waste"] },
        "direction": { "enum": ["input", "output"] },
        "amount": { "type": ["number", "null"], "exclusiveMinimum": 0 },
        "unit": { "type": "string" },
        "provider_database": { "type": "string" },
        "provider_code": { "type": "string" },
        "data_source": { "type": "string" },
        "uncertainty": { "$ref": "#/$defs/uncertainty" }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "parameter"],
      "properties": {
        "type": { "enum": ["none", "lognormal", "normal", "triangular", "uniform", "pedigree"] },
        "parameter": { "type": "string" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ready", "exchange_count", "quantified_exchange_count", "mapped_exchange_count"],
      "properties": {
        "ready": { "type": "boolean" },
        "exchange_count": { "type": "integer", "minimum": 0 },
        "quantified_exchange_count": { "type": "integer", "minimum": 0 },
        "mapped_exchange_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
