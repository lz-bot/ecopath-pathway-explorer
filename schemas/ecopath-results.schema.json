{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lz-bot.github.io/ecopath-pathway-explorer/schemas/ecopath-results.schema.json",
  "title": "ECO-PATH Brightway results",
  "type": "object",
  "required": ["schema_version", "scenario_id", "functional_unit", "methods"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "scenario_id": { "type": "string", "minLength": 1 },
    "functional_unit": { "type": "object" },
    "cohort_size": { "type": "number", "exclusiveMinimum": 0 },
    "methods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["category_id", "unit", "score_per_functional_unit"],
        "properties": {
          "category_id": { "type": "string", "minLength": 1 },
          "unit": { "type": "string", "minLength": 1 },
          "score_per_functional_unit": { "type": "number" },
          "score_for_cohort": { "type": "number" }
        }
      }
    }
  }
}
