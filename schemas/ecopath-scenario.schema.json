{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lz-bot.github.io/ecopath-pathway-explorer/schemas/ecopath-scenario.schema.json",
  "title": "ECO-PATH Brightway scenario",
  "type": "object",
  "required": ["schema_version", "scenario_id", "functional_unit", "building_blocks"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "scenario_id": { "type": "string", "minLength": 1 },
    "assessment": {
      "type": "object",
      "required": ["mode", "valid", "result_label"],
      "properties": {
        "mode": { "enum": ["complete", "partial"] },
        "valid": { "const": true },
        "result_label": { "type": "string", "minLength": 1 },
        "declared_start": { "type": ["string", "null"] },
        "declared_endpoint": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "functional_unit": {
      "type": "object",
      "required": ["statement"],
      "properties": { "statement": { "type": "string", "minLength": 1 } }
    },
    "cohort_size": { "type": "number", "exclusiveMinimum": 0 },
    "calculation_options": {
      "type": "object",
      "properties": {
        "with_contributions": { "type": "boolean" },
        "contribution_categories": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "building_blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["mapping_key", "quantity_per_functional_unit", "enabled"],
        "properties": {
          "mapping_key": { "type": "string", "minLength": 1 },
          "quantity_per_functional_unit": { "type": "number", "minimum": 0 },
          "enabled": { "type": "boolean" }
        }
      }
    }
  }
}
